-- Keyspace creation and activation
CREATE KEYSPACE tokio 
WITH replication = {'class': 'SimpleStrategy', 'replication_factor': 1};
USE tokio;

-- Creation of member and course tables
CREATE TABLE membro (
    cartao_de_cidadao text,
    data_de_nascimento date,
    email text,
    nome text,
    apelidos text,
    tipo text STATIC,
    PRIMARY KEY (cartao_de_cidadao, data_de_nascimento)
);
CREATE TABLE cursos (
    nome text,
    data_de_publicacao timestamp,
    professor map<text, text>,
    categoria text,
    duracao int,
    PRIMARY KEY (nome, data_de_publicacao)
);

-- Creation of member and course tables and adding descriptive comment to the courses table metadata
ALTER TABLE membro ADD interesses list<text>;
ALTER TABLE cursos WITH comment = 'Tabela que armazena os cursos oferecidos pela plataforma Tokio';

