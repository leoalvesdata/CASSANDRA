-- Course query by name (Partition Key)
SELECT * FROM cursos WHERE nome = 'Curso de Cassandra';

-- Query courses by category (Requires Secondary Index)
-- Creation of mandatory index for columns outside the Primary Key
CREATE INDEX ON cursos (categoria);
SELECT * FROM cursos WHERE categoria = 'Programacao';

